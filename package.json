{
  "name": "byte-alchemy",
  "version": "0.2.0",
  "description": "Local reverse-engineering and crypto analysis workbench",
  "main": "electron/main.js",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "pnpm -C front dev",
    "build": "pnpm -C front build",
    "preview": "pnpm -C front preview",
    "electron:dev": "pnpm -C front build && electron . --no-sandbox",
    "electron:build": "pnpm -C front build && electron-builder",
    "start": "electron . --no-sandbox"
  },
  "keywords": [],
  "author": "QAQ",
  "license": "ISC",
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.decoder.pro",
    "productName": "ByteAlchemy",
    "directories": {
      "output": "release"
    },
    "files": [
      "front/dist/**/*",
      "electron/**/*",
      "package.json",
      "data/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "python-dist/backend-server",
        "to": "backend-server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "dir"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.utilities"
    }
  }
}
